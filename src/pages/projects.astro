---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import { TiltCard } from '../components/react/TiltCard'
import { projectsData } from '../data/projectsData'
---

<BaseLayout
  title="Projects"
  description="Selected client and personal projects — full-stack apps, SaaS, and prototypes built with React, TypeScript, Next.js, and cloud platforms."
  fullBleed
>
  <Navigation slot="header" />

  <div class="inner-page">
    <div class="container">
      <header class="page-header">
        <span class="section-label">Work</span>
        <h1 class="page-title">Projects</h1>
        <p class="page-subtitle">
          Client work, personal projects, and experiments —
          built with care across the full stack.
        </p>
      </header>

      <div class="projects-all-grid">
        {projectsData.map((p, i) => (
          <TiltCard
            client:visible
            title={p.title}
            description={p.description}
            imageSrc={p.imgSrc}
            href={p.href}
            externalHref={p.externalHref}
            skills={p.skills}
            date={p.date}
            rotationFactor={10}
          />
        ))}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .projects-all-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .projects-all-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
