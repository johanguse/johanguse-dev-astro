---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import { siteConfig } from '../data/siteConfig'
---

<BaseLayout
  title="About"
  description="About Johan Guse — Design Engineer from Brazil. Experience across full-stack web, React, TypeScript, and cloud platforms."
  fullBleed
>
  <Navigation slot="header" />

  <div class="inner-page">
    <div class="container">
      <header class="page-header">
        <span class="section-label">Human</span>
        <h1 class="page-title">About</h1>
      </header>

      <div class="about-layout">
        <!-- Left: photo + identity -->
        <aside class="about-aside">
          <div class="about-photo-wrap">
            <img
              src="https://res.cloudinary.com/dvcywi3uf/image/upload/v1652237380/pics/me-4x4.jpg"
              alt="Photo of Johan Guse"
              loading="eager"
              fetchpriority="high"
              width="240"
              height="240"
              class="about-photo"
            />
          </div>

          <div class="about-identity">
            <p class="about-name">{siteConfig.author}</p>
            <p class="about-role-tag">Design Engineer</p>
            <p class="about-location">Brazil</p>
          </div>

          <div class="about-social">
            <a href={`mailto:${siteConfig.email}`} class="about-social-link" aria-label="Email">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" /><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" /></svg>
              Email
            </a>
            <a href={siteConfig.github} class="about-social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
              GitHub
            </a>
            <a href={siteConfig.linkedin} class="about-social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
              LinkedIn
            </a>
            <a href={siteConfig.twitter} class="about-social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" /></svg>
              Twitter
            </a>
          </div>
        </aside>

        <!-- Right: bio content -->
        <div class="about-content">
          <p class="about-lead">
            I'm a Design Engineer from Brazil who's been building for the web since 2006.
          </p>

          <div class="about-prose">
            <p>
              I work in the space between design and engineering — where a component needs to
              be both pixel-perfect and battle-tested. I believe the best digital products are
              the ones you <em>feel</em> before you understand them.
            </p>
            <p>
              Over the past decade-plus I've shipped full-stack applications spanning AI-powered
              tools, real-time systems, SaaS platforms, and content experiences — using React,
              TypeScript, Node.js, and whatever else the problem actually needs.
            </p>
            <p>
              Currently pursuing Applied Artificial Intelligence studies while building
              production platforms that leverage LLMs and modern cloud architectures.
              Passionate about accessibility, performance, and the craft of building things
              that last.
            </p>
          </div>

          <div class="about-skills">
            <h2 class="about-skills-heading">Things I work with</h2>
            <div class="skills-grid">
              {[
                'React', 'TypeScript', 'Next.js', 'Astro',
                'Node.js', 'PostgreSQL', 'Tailwind CSS', 'Cloudflare',
                'Figma', 'Design Systems', 'AI / LLMs', 'Accessibility',
              ].map(skill => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>

          <div class="about-cta">
            <a href={`mailto:${siteConfig.email}`} class="btn-primary">
              Get in touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .about-layout {
      grid-template-columns: 280px 1fr;
      gap: 5rem;
    }
  }

  /* Aside */
  .about-aside {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .about-photo-wrap {
    width: 160px;
    height: 160px;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .about-photo-wrap {
      width: 100%;
      height: 280px;
    }
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-identity {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .about-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-1);
    margin: 0;
  }

  .about-role-tag {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    margin: 0;
  }

  .about-location {
    font-size: 0.8rem;
    color: var(--text-3);
    margin: 0;
    margin-top: 0.1rem;
  }

  .about-social {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .about-social-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.4rem 0;
    transition: color 0.15s ease;
  }

  .about-social-link:hover {
    color: var(--accent);
  }

  .about-social-link svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* Content */
  .about-lead {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 2rem;
  }

  .about-prose {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .about-prose p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-2);
    margin: 0;
    max-width: 60ch;
  }

  .about-prose em {
    color: var(--text-1);
    font-style: italic;
  }

  .about-skills {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .about-skills-heading {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 0 0 1.25rem;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    background: var(--bg-elevated);
    color: var(--text-2);
    border: 1px solid var(--border);
  }

  .about-cta {
    display: flex;
    gap: 1rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--btn-bg);
    color: var(--btn-text);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 0.6rem;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
</style>
