---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navigation from '../../components/Navigation.astro'
import Footer from '../../components/Footer.astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import { formatDate } from '../../utils/helpers'
import { tagToUrlPath } from '../../utils/tagUrl'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog')
  const groups = new Map<string, { displayLabel: string; posts: CollectionEntry<'blog'>[] }>()

  for (const post of posts) {
    if (post.data.draft) continue
    for (const rawTag of post.data.tags ?? []) {
      const key = tagToUrlPath(rawTag)
      if (!groups.has(key)) {
        groups.set(key, { displayLabel: rawTag, posts: [] })
      }
      const g = groups.get(key)
      if (g && !g.posts.some((p) => p.id === post.id)) {
        g.posts.push(post)
      }
    }
  }

  return Array.from(groups.entries()).map(([tagParam, { displayLabel, posts: tagPosts }]) => ({
    params: { tag: tagParam },
    props: {
      tagDisplay: displayLabel,
      posts: tagPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }))
}) satisfies GetStaticPaths

const { tagDisplay, posts } = Astro.props
---

<BaseLayout
  title={`#${tagDisplay}`}
  description={`Blog posts tagged "${tagDisplay}" — development, tutorials, and notes by Johan Guse.`}
  fullBleed
>
  <Navigation slot="header" />

  <div class="inner-page">
    <div class="container">
      <header class="page-header">
        <span class="section-label">Tag</span>
        <h1 class="page-title">#{tagDisplay}</h1>
        <p class="page-subtitle">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
      </header>

      <ul class="posts-list" role="list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}/`} class="post-link">
              <time class="post-date" datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <span class="post-title">{post.data.title}</span>
              <span class="post-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>

      <div style="margin-top: 2.5rem;">
        <a href="/blog/" class="cta-link">&larr; All writing</a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-top: 1px solid var(--border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-link:hover .post-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .post-date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.04em;
    white-space: nowrap;
    min-width: 7rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-arrow {
    font-size: 1rem;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.15s ease;
  }

  .cta-link:hover {
    border-color: var(--accent);
  }
</style>
