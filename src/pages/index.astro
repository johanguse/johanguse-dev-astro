---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { siteConfig } from '../data/siteConfig'
import { projectsData } from '../data/projectsData'
import { getCollection } from 'astro:content'
import { formatDate } from '../utils/helpers'
import { tagToUrlPath } from '../utils/tagUrl'

const featuredProjects = projectsData.slice(0, 6)

const allPosts = await getCollection('blog')
const blogPosts = allPosts
	.filter(post => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 5)
---

<BaseLayout
	title="Portfolio, projects & technical blog"
	description="Personal portfolio and blog by Johan Guse — full-stack engineering, React, TypeScript, cloud, and web performance. Based in Brazil."
>
	<Navigation slot="header" />

	<div class="divide-y divide-gray-200 dark:divide-gray-700">
		<!-- Latest Works -->
		<div class="mb-14 mt-7">
			<h1 class="mb-3 text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
				Latest Works
			</h1>
			<p class="mb-8 text-lg leading-7 text-gray-500 dark:text-gray-400">
				Check out my latest works!
			</p>
			<div class="-m-4 mb-6 flex flex-wrap">
				{featuredProjects.map((project, index) => (
					<ProjectCard
						title={project.title}
						description={project.description}
						imgSrc={project.imgSrc}
						href={project.href}
						date={project.date}
						skills={project.skills}
						clientName={project.clientName}
						clientURL={project.clientURL}
						externalHref={project.externalHref}
						imagePriority={index < 2}
					/>
				))}
			</div>
			<div class="flex justify-center text-base font-medium leading-6 pb-6">
				<a href="/projects/" class="text-primary-500 dark:text-primary-100 hover:text-primary-600 dark:hover:text-white">
					Check out all projects &rarr;
				</a>
			</div>
		</div>

		<!-- Latest from Blog -->
		<div class="mb-14 space-y-2 pb-8 pt-6 md:space-y-5">
			<h2 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
				Latest from blog
			</h2>
			<p class="text-lg leading-7 text-gray-500 dark:text-gray-400">
				{siteConfig.description}
			</p>

			<ul class="divide-y divide-gray-200 dark:divide-gray-700">
				{blogPosts.map((post) => (
					<li class="py-12">
						<article>
							<div class="space-y-2 xl:grid xl:grid-cols-4 xl:items-baseline xl:space-y-0">
								<dl>
									<dt class="sr-only">Published on</dt>
									<dd class="text-base font-medium leading-6 text-gray-500 dark:text-gray-400">
										<time datetime={post.data.date.toISOString()}>
											{formatDate(post.data.date)}
										</time>
									</dd>
								</dl>
								<div class="space-y-5 xl:col-span-3">
									<div class="space-y-6">
										<div>
											<h2 class="text-2xl font-bold leading-8 tracking-tight">
												<a href={`/blog/${post.id}/`} class="text-gray-900 dark:text-gray-100">
													{post.data.title}
												</a>
											</h2>
											{post.data.tags && (
												<div class="flex flex-wrap">
													{post.data.tags.map((tag) => (
														<a href={`/tags/${tagToUrlPath(tag)}/`} class="mr-3 text-sm font-medium uppercase text-primary-500 dark:text-primary-100 hover:text-primary-600 dark:hover:text-white">
															{tag}
														</a>
													))}
												</div>
											)}
										</div>
										<div class="prose max-w-none text-gray-500 dark:text-gray-400">
											{post.data.description}
										</div>
									</div>
									<div class="text-base font-medium leading-6">
										<a href={`/blog/${post.id}/`} class="text-primary-500 dark:text-primary-100 hover:text-primary-600 dark:hover:text-white">
											Read more: {post.data.title} &rarr;
										</a>
									</div>
								</div>
							</div>
						</article>
					</li>
				))}
			</ul>

			{allPosts.length > 5 && (
				<div class="flex justify-end text-base font-medium leading-6">
					<a href="/blog/" class="text-primary-500 dark:text-primary-100 hover:text-primary-600 dark:hover:text-white">
						All Posts &rarr;
					</a>
				</div>
			)}
		</div>
	</div>

	<Footer slot="footer" />
</BaseLayout>
