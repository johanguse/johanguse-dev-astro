---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import { TiltCard } from '../components/react/TiltCard'
import { TextReveal } from '../components/react/TextReveal'
import { PixelBackground } from '../components/react/PixelBackground'
import { projectsData } from '../data/projectsData'
import { getCollection } from 'astro:content'
import { formatDate } from '../utils/helpers'

const featuredProjects = projectsData.slice(0, 3)

const allPosts = await getCollection('blog')
const blogPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4)
---

<BaseLayout
  title="Johan Guse — Design Engineer"
  description="Design Engineer building interfaces that feel as good as they work. Based in Brazil."
  fullBleed
>
  <Navigation slot="header" />

  <!-- ═══ HERO ════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Introduction">
    <PixelBackground
      client:load
      gap={8}
      speed={32}
      pattern="center"
      darkColors="#2e2a45,#252238,#332b1a"
      lightColors="#d2cfe0,#c5c2d4,#b8b5c8"
      className="hero-canvas"
    >
      <div class="hero-inner">
        <!-- Left: text content -->
        <div class="hero-content">
          <p class="hero-eyebrow">
            <span class="hero-dot" aria-hidden="true" />
            Available for work &mdash; based in Brazil
          </p>

          <h1 class="hero-heading">
            Hi, I'm Johan.<br />
            I design &amp; <em class="hero-accent">engineer</em><br />
            interfaces.
          </h1>

          <p class="hero-tagline">
            Design Engineer building interfaces that feel
            as good as they work. Based in Brazil.
          </p>

          <div class="hero-actions">
            <a href="#work" class="btn-primary">View work &rarr;</a>
            <a href="/blog/" class="btn-ghost">Writing</a>
          </div>
        </div>

        <!-- Right: terminal panel -->
        <div class="hero-terminal" aria-hidden="true">
          <div class="terminal-bar">
            <span class="terminal-dot terminal-dot--red"></span>
            <span class="terminal-dot terminal-dot--yellow"></span>
            <span class="terminal-dot terminal-dot--green"></span>
          </div>
          <div class="terminal-body">
            <p class="terminal-line">
              <span class="terminal-prompt">$</span> whoami
            </p>
            <p class="terminal-line terminal-line--accent">
              johanguse &mdash; design engineer
            </p>
            <p class="terminal-line terminal-line--gap">
              <span class="terminal-prompt">$</span> skills --list
            </p>
            <p class="terminal-line terminal-line--output">&gt; React, TypeScript, Next.js</p>
            <p class="terminal-line terminal-line--output">&gt; Design Systems, Tailwind CSS</p>
            <p class="terminal-line terminal-line--output">&gt; Motion, Framer Motion, UX</p>
            <p class="terminal-line terminal-line--gap">
              <span class="terminal-prompt">$</span> availability
            </p>
            <p class="terminal-line terminal-line--success">&gt; open to projects in 2026</p>
            <p class="terminal-line terminal-line--gap">
              <span class="terminal-prompt">$</span> building interfaces &rarr;<span class="terminal-cursor">_</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="scroll-hint" aria-hidden="true">
        <div class="scroll-hint-line" />
      </div>
    </PixelBackground>
  </section>

  <!-- ═══ SELECTED WORK ═══════════════════════════════════════════ -->
  <section id="work" class="section" aria-label="Selected projects">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Selected Work</span>
        <TextReveal
          client:visible
          text="Things I've built that I'm proud of."
          as="h2"
          className="section-heading"
          staggerDelay={0.045}
          duration={0.6}
        />
      </div>

      <!-- Projects grid: featured card full-width, two below -->
      <div class="projects-grid">
        {featuredProjects.map((p, i) => (
          <div class:list={['project-slot', i === 0 ? 'project-slot--featured' : 'project-slot--secondary']}>
            <TiltCard
              client:visible
              title={p.title}
              description={p.description}
              imageSrc={p.imgSrc}
              href={p.href}
              externalHref={p.externalHref}
              skills={p.skills}
              date={p.date}
              rotationFactor={i === 0 ? 8 : 11}
              imageHeight={i === 0 ? 260 : 180}
            />
          </div>
        ))}
      </div>

      <div class="section-cta">
        <a href="/projects/" class="cta-link">All projects &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT ════════════════════════════════════════════════════ -->
  <section class="section section--about" aria-label="About Johan">
    <div class="container">
      <div class="about-grid">
        <div class="about-left">
          <span class="section-label">About</span>
          <div class="about-role">
            <span class="about-role-line">Design</span>
            <span class="about-role-line about-role-line--muted">Engineer</span>
          </div>
        </div>
        <div class="about-right">
          <TextReveal
            client:visible
            text="I'm a Design Engineer from Brazil who believes the best digital products are the ones you feel before you understand them."
            as="p"
            className="about-statement"
            staggerDelay={0.022}
            duration={0.65}
          />
          <p class="about-body">
            I work in the space between design systems and production code —
            where a component needs to be both pixel-perfect and battle-tested.
            Currently focused on React, TypeScript, and building things that last.
          </p>
          <div class="about-actions">
            <a href="/about/" class="cta-link">Full story &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WRITING ══════════════════════════════════════════════════ -->
  <section class="section" aria-label="Recent writing">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Writing</span>
        <h2 class="section-heading">Thoughts &amp; notes</h2>
      </div>

      <ul class="posts-list" role="list">
        {blogPosts.map((post, i) => (
          <li class="post-item" style={`--i: ${i}`}>
            <a href={`/blog/${post.id}/`} class="post-link">
              <time class="post-date" datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <span class="post-title">{post.data.title}</span>
              <span class="post-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="section-cta">
        <a href="/blog/" class="cta-link">All writing &rarr;</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
  }

  .hero-canvas {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 6rem;
  }

  .hero-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
    padding-top: 4rem; /* clear fixed nav */
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    width: 100%;
  }

  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
    }
  }

  /* Left: text */
  .hero-content {}

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 2rem;
    background: color-mix(in oklch, var(--bg) 70%, transparent);
    border: 1px solid var(--border);
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
  }

  .hero-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: oklch(0.65 0.2 145);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.8); }
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: var(--text-1);
    margin: 0 0 1.75rem;
  }

  .hero-accent {
    font-style: italic;
    color: var(--accent);
    font-weight: 700;
  }

  .hero-tagline {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    font-weight: 400;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0 0 2.5rem;
    max-width: 42ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Terminal panel ───────────────────────────────────────────── */
  .hero-terminal {
    background: oklch(0.11 0.018 275 / 0.92);
    backdrop-filter: blur(16px) saturate(1.2);
    border: 1px solid oklch(0.28 0.025 275 / 0.7);
    border-radius: 0.875rem;
    overflow: hidden;
    box-shadow:
      0 32px 64px -16px oklch(0 0 0 / 0.45),
      0 0 0 1px oklch(1 0 0 / 0.04) inset;
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 1.2vw, 0.85rem);
    line-height: 1.8;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid oklch(0.22 0.02 275 / 0.8);
    background: oklch(0.09 0.015 275 / 0.6);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot--red    { background: #ff5f57; }
  .terminal-dot--yellow { background: #ffbd2e; }
  .terminal-dot--green  { background: #28c840; }

  .terminal-body {
    padding: 1.25rem 1.4rem 1.5rem;
  }

  .terminal-line {
    margin: 0;
    color: oklch(0.72 0.025 270);
  }

  .terminal-line--gap {
    margin-top: 0.5rem;
  }

  .terminal-line--output {
    color: oklch(0.58 0.02 270);
    padding-left: 0.25rem;
  }

  .terminal-line--accent {
    color: oklch(0.70 0.14 52);
    padding-left: 0.25rem;
  }

  .terminal-line--success {
    color: oklch(0.72 0.18 145);
    padding-left: 0.25rem;
  }

  .terminal-prompt {
    color: oklch(0.70 0.14 52);
    margin-right: 0.5rem;
    user-select: none;
  }

  .terminal-cursor {
    display: inline-block;
    animation: blink 1.1s step-end infinite;
    color: oklch(0.70 0.14 52);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    background: var(--btn-bg);
    color: var(--btn-text);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    border-radius: 0.6rem;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--text-2);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .btn-ghost:hover {
    color: var(--text-1);
    border-color: var(--text-3);
    background: var(--bg-elevated);
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    opacity: 0.35;
  }

  .scroll-hint-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--text-2), transparent);
    animation: scrollDown 1.8s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
    40%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
    60%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ── Sections ─────────────────────────────────────────────────── */
  .section {
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .section--about {
    background: var(--bg-elevated);
    border-block: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .section-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-1);
    line-height: 1.05;
    margin: 0;
  }

  /* ── Projects grid ────────────────────────────────────────────── */
  /*
   * Layout:
   *   mobile  → 1 column, all stacked
   *   ≥640px  → featured spans full width, secondaries side by side below
   */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Featured card spans both columns */
    .project-slot--featured {
      grid-column: 1 / -1;
    }

    /* The two secondary cards share the row below */
    .project-slot--secondary {
      grid-column: span 1;
    }
  }

  /* ── About ────────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    gap: 3rem 5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 2fr;
    }
  }

  .about-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .about-role {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }

  .about-role-line--muted {
    color: var(--text-3);
  }

  .about-statement {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 1.5rem;
  }

  .about-body {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-2);
    max-width: 58ch;
    margin: 0 0 2rem;
  }

  .about-actions {
    margin-top: 0.5rem;
  }

  /* ── Writing ──────────────────────────────────────────────────── */
  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-top: 1px solid var(--border);
    transition: background 0.15s ease;
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-link:hover .post-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .post-date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.04em;
    white-space: nowrap;
    min-width: 7rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .post-arrow {
    font-size: 1rem;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  /* ── CTA link ─────────────────────────────────────────────────── */
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--accent) 35%, transparent);
    padding-bottom: 1px;
    transition: border-color 0.15s ease;
  }

  .cta-link:hover {
    border-color: var(--accent);
  }

  .section-cta {
    margin-top: 2.5rem;
  }
</style>
