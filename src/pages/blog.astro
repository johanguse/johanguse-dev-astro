---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import { getCollection } from 'astro:content'
import { formatDate } from '../utils/helpers'
import { tagToUrlPath } from '../utils/tagUrl'

const allPosts = await getCollection('blog')
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
  title="Writing"
  description="Notes on web development, design systems, tooling, React, TypeScript, and building for the web."
  fullBleed
>
  <Navigation slot="header" />

  <div class="inner-page">
    <div class="container">
      <header class="page-header">
        <span class="section-label">Writing</span>
        <h1 class="page-title">All Posts</h1>
        <p class="page-subtitle">
          {sortedPosts.length} posts on development, design, and building for the web.
        </p>
      </header>

      {sortedPosts.length === 0 ? (
        <p class="empty-state">No posts yet — check back soon.</p>
      ) : (
        <ul class="posts-list" role="list">
          {sortedPosts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} class="post-link">
                <time class="post-date" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                <div class="post-body">
                  <span class="post-title">{post.data.title}</span>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map(tag => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <span class="post-arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .empty-state {
    color: var(--text-3);
    font-size: 1rem;
    padding: 3rem 0;
  }

  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-top: 1px solid var(--border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-link:hover .post-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .post-date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.04em;
    white-space: nowrap;
    min-width: 7rem;
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  .post-arrow {
    font-size: 1rem;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  @media (max-width: 540px) {
    .post-link {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }
    .post-date {
      grid-column: 1 / -1;
      min-width: unset;
    }
    .post-body {
      grid-column: 1;
    }
  }
</style>
